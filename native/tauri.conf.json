{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "gimp-mcp",
  "version": "0.1.0",
  "identifier": "ai.fleet.gimp-mcp",
  "build": {
    "frontendDist": "../webapp/frontend/dist",
    "devUrl": "http://localhost:10772"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "GIMP MCP",
        "width": 1280,
        "height": 860,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/gimp-mcp-backend.exe"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "skip"
      },
      "nsis": {}
    }
  },
  "plugins": {}
}