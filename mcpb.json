{
  "name": "gimp-mcp",
  "version": "4.0.0",
  "type": "server",
  "runtime": "python",
  "entry_point": "src/gimp_mcp/mcp_server.py",
  "dependencies": ["fastmcp>=3.2.0"],
  "build": {
    "include": [
      "src/**/*",
      "README.md",
      "LICENSE",
      "mcpb/**/*",
      "skills/**/*",
      "llms.txt"
    ],
    "exclude": [
      "tests/",
      ".git/",
      "__pycache__/",
      "*.pyc",
      ".venv/",
      "dist/",
      "build/",
      "target/",
      "*.mcpb",
      ".pytest_cache/",
      "webapp/frontend/node_modules/"
    ]
  },
  "scripts": {
    "build": "python build_mcpb.py",
    "test": "python -m pytest",
    "lint": "ruff check src"
  }
}
